<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:PhiFanmade.Tool.Gui.ViewModels"
             xmlns:mi="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
             xmlns:loc="clr-namespace:PhiFanmade.Tool.Localization;assembly=PhiFanmade.Tool.Localization"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             x:Class="PhiFanmade.Tool.Gui.Views.RpeLayerMergeView"
             x:DataType="vm:RpeLayerMergeViewModel">

    <DockPanel>
        <!-- ── 顶部标题栏 ── -->
        <Border DockPanel.Dock="Top"
                Padding="24,18,24,14"
                BorderThickness="0,0,0,1"
                BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}">
            <StackPanel Spacing="4">
                <StackPanel Orientation="Horizontal" Spacing="10">
                    <mi:MaterialIcon Kind="Layers" Width="26" Height="26" VerticalAlignment="Center"/>
                    <TextBlock Text="{x:Static loc:Strings.gui_nav_rpe_layer_merge}"
                               FontSize="20" FontWeight="SemiBold"
                               VerticalAlignment="Center"/>
                </StackPanel>
                <TextBlock Text="{x:Static loc:Strings.gui_page_merge_subtitle}"
                           Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                           FontSize="12" Margin="36,0,0,0"/>
            </StackPanel>
        </Border>
        <!-- ── 主内容区 ── -->
        <ScrollViewer Padding="16,12,16,8">
            <StackPanel Spacing="14">

                <!-- 输入来源卡片 -->
                <Border Classes="card" Padding="16,14">
                    <StackPanel Spacing="10">
                        <StackPanel Orientation="Horizontal" Spacing="7">
                            <mi:MaterialIcon Kind="FolderOpen" Width="16" Height="16" VerticalAlignment="Center"/>
                            <TextBlock Text="{x:Static loc:Strings.gui_section_input_source}"
                                       FontWeight="SemiBold" FontSize="13" VerticalAlignment="Center"/>
                        </StackPanel>
                        <Grid ColumnDefinitions="Auto,*,Auto" RowDefinitions="Auto,8,Auto">
                            <TextBlock Grid.Row="0" Grid.Column="0"
                                       Text="{x:Static loc:Strings.gui_label_file_path}"
                                       Width="80" VerticalAlignment="Center"
                                       Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
                            <TextBox   Grid.Row="0" Grid.Column="1"
                                       Text="{Binding InputPath}"
                                       Watermark="{x:Static loc:Strings.gui_watermark_input_from_workspace}"
                                       Margin="0,0,6,0"/>
                            <Button    Grid.Row="0" Grid.Column="2" Command="{Binding BrowseInputCommand}">
                                <StackPanel Orientation="Horizontal" Spacing="4">
                                    <mi:MaterialIcon Kind="FolderOpen" Width="14" Height="14" VerticalAlignment="Center"/>
                                    <TextBlock Text="{x:Static loc:Strings.gui_btn_browse}" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>

                            <TextBlock Grid.Row="2" Grid.Column="0"
                                       Text="{x:Static loc:Strings.gui_label_workspace_id}"
                                       Width="80" VerticalAlignment="Center"
                                       Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
                            <TextBox   Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="2"
                                       Text="{Binding WorkspaceId}"
                                       Watermark="{x:Static loc:Strings.gui_watermark_workspace_or_file}"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- 输出卡片 -->
                <Border Classes="card" Padding="16,14">
                    <StackPanel Spacing="10">
                        <StackPanel Orientation="Horizontal" Spacing="7">
                            <mi:MaterialIcon Kind="ContentSave" Width="16" Height="16" VerticalAlignment="Center"/>
                            <TextBlock Text="{x:Static loc:Strings.gui_section_output}"
                                       FontWeight="SemiBold" FontSize="13" VerticalAlignment="Center"/>
                        </StackPanel>
                        <Grid ColumnDefinitions="Auto,*,Auto">
                            <TextBlock Grid.Column="0"
                                       Text="{x:Static loc:Strings.gui_label_output_path}"
                                       Width="80" VerticalAlignment="Center"
                                       Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
                            <TextBox   Grid.Column="1"
                                       Text="{Binding OutputPath}"
                                       Watermark="{x:Static loc:Strings.gui_watermark_output_auto}"
                                       Margin="0,0,6,0"/>
                            <Button    Grid.Column="2" Command="{Binding BrowseOutputCommand}">
                                <StackPanel Orientation="Horizontal" Spacing="4">
                                    <mi:MaterialIcon Kind="FolderOpen" Width="14" Height="14" VerticalAlignment="Center"/>
                                    <TextBlock Text="{x:Static loc:Strings.gui_btn_browse}" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- 参数卡片 -->
                <Border Classes="card" Padding="16,14">
                    <StackPanel Spacing="10">
                        <StackPanel Orientation="Horizontal" Spacing="7">
                            <mi:MaterialIcon Kind="Tune" Width="16" Height="16" VerticalAlignment="Center"/>
                            <TextBlock Text="{x:Static loc:Strings.gui_section_params}"
                                       FontWeight="SemiBold" FontSize="13" VerticalAlignment="Center"/>
                        </StackPanel>
                        <Grid ColumnDefinitions="Auto,*,Auto,*" RowDefinitions="Auto,8,Auto">
                            <TextBlock Grid.Row="0" Grid.Column="0"
                                       Text="{x:Static loc:Strings.gui_label_precision}"
                                       VerticalAlignment="Center" Margin="0,0,10,0"
                                       ToolTip.Tip="{x:Static loc:Strings.gui_tooltip_precision}"
                                       Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
                            <NumericUpDown Grid.Row="0" Grid.Column="1"
                                           Value="{Binding Precision}" Minimum="1" Maximum="1024"
                                           Increment="8" FormatString="0"/>

                            <TextBlock Grid.Row="0" Grid.Column="2"
                                       Text="{x:Static loc:Strings.gui_label_tolerance}"
                                       VerticalAlignment="Center" Margin="12,0,10,0"
                                       ToolTip.Tip="{x:Static loc:Strings.gui_tooltip_tolerance}"
                                       Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
                            <NumericUpDown Grid.Row="0" Grid.Column="3"
                                           Value="{Binding Tolerance}" Minimum="0" Maximum="100"
                                           Increment="1" FormatString="0"/>

                            <CheckBox Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="4"
                                      Content="{x:Static loc:Strings.gui_check_dry_run}"
                                      IsChecked="{Binding DryRun}"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- 执行按钮行 -->
                <Grid ColumnDefinitions="*,Auto,Auto" Margin="0,4,0,0">
                    <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                        <mi:MaterialIcon Kind="InformationOutline" Width="14" Height="14"
                                         Opacity="0.6" VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding Status}"
                                   Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                                   FontSize="12" VerticalAlignment="Center"/>
                    </StackPanel>
                    <Button Grid.Column="1" Margin="0,0,8,0"
                            Command="{Binding RunCancelCommand}" IsVisible="{Binding IsBusy}">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <mi:MaterialIcon Kind="StopCircleOutline" Width="16" Height="16" VerticalAlignment="Center"/>
                            <TextBlock Text="{x:Static loc:Strings.gui_btn_cancel}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button Grid.Column="2" FontSize="14" Padding="22,8"
                            Command="{Binding RunCommand}" IsEnabled="{Binding !IsBusy}">
                        <Button.Styles>
                            <Style Selector="Button">
                                <Setter Property="Background" Value="#2e7d52"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Style>
                            <Style Selector="Button:pointerover /template/ ContentPresenter#PART_ContentPresenter">
                                <Setter Property="Background" Value="#3da06a"/>
                            </Style>
                            <Style Selector="Button:disabled /template/ ContentPresenter#PART_ContentPresenter">
                                <Setter Property="Background" Value="#304040"/>
                            </Style>
                        </Button.Styles>
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <mi:MaterialIcon Kind="PlayCircleOutline" Width="18" Height="18" VerticalAlignment="Center"/>
                            <TextBlock Text="{x:Static loc:Strings.gui_btn_start_merge}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </Grid>

            </StackPanel>
        </ScrollViewer>
    </DockPanel>
</UserControl>

