<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:PhiFanmade.Tool.Gui.ViewModels"
        xmlns:mi="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
        xmlns:loc="clr-namespace:PhiFanmade.Tool.Localization;assembly=PhiFanmade.Tool.Localization"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="960" d:DesignHeight="640"
        x:Class="PhiFanmade.Tool.Gui.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/PhiFanmadeToolIcon.png"
        Title="PhiFanmade 工具集"
        Width="960" Height="640"
        MinWidth="760" MinHeight="500">

    <Design.DataContext>
        <!-- This only sets the DataContext for the previewer in an IDE,
             to set the actual DataContext for runtime, set the DataContext property in code (look at App.axaml.cs) -->
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <Grid ColumnDefinitions="210,*">

        <!-- ══ 侧边栏 ═══════════════════════════════════════════════════════ -->
        <Border Grid.Column="0" Background="#12121e">
            <DockPanel>
                <!-- 应用标题 -->
                <Border DockPanel.Dock="Top" Padding="16,20,16,12">
                    <StackPanel Spacing="6">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Image Source="/Assets/PhiFanmadeToolIcon.png"
                                   Width="20" Height="20"
                                   VerticalAlignment="Center"
                                   RenderOptions.BitmapInterpolationMode="HighQuality"/>
                            <TextBlock Text="PhiFanmade"
                                       Foreground="White"
                                       FontSize="16" FontWeight="Bold"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                        <TextBlock Text="{x:Static loc:Strings.gui_app_subtitle}"
                                   Foreground="#8888aa"
                                   FontSize="11"/>
                    </StackPanel>
                </Border>

                <!-- 分割线 -->
                <Border DockPanel.Dock="Top" Height="1" Background="#2a2a3e" Margin="12,0"/>

                <!-- 版本号 (底部) -->
                <Border DockPanel.Dock="Bottom" Padding="16,12">
                    <TextBlock Text="{x:Static loc:Strings.gui_version_label}"
                               Foreground="#555566"
                               FontSize="11"/>
                </Border>

                <!-- 导航项列表 -->
                <ListBox Classes="nav"
                         Background="Transparent"
                         BorderThickness="0"
                         Margin="0,8,0,0"
                         ItemsSource="{Binding NavItems}"
                         SelectedItem="{Binding SelectedNavItem}">
                    <ListBox.ItemTemplate>
                        <DataTemplate x:DataType="vm:NavItem">
                            <StackPanel Orientation="Horizontal" Spacing="10"
                                        Classes.locked="{Binding !IsEnabled}">
                                <StackPanel.Styles>
                                    <Style Selector="StackPanel.locked">
                                        <Setter Property="Opacity" Value="0.4"/>
                                    </Style>
                                </StackPanel.Styles>
                                <mi:MaterialIcon Kind="{Binding Icon}"
                                                 Width="18" Height="18"
                                                 VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding Title}"
                                           VerticalAlignment="Center"
                                           FontSize="13"/>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>
        </Border>

        <!-- ══ 主内容区 ══════════════════════════════════════════════════════ -->
        <ContentControl Grid.Column="1"
                        Content="{Binding CurrentPage}"/>
    </Grid>
</Window>
